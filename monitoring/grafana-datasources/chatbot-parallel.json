{
  "dashboard": {
    "title": "Chatbot Distribuido - Métricas de Paralelismo",
    "panels": [
      {
        "title": "CPU Usage",
        "type": "graph",
        "targets": [{
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }]
      }
    ]
  }
}